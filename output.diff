+            </div>
+          </div>
+
+          <div class="field">
+            <div class="field-label">
+              <div class="field-title">Screenshot preview interval (seconds)</div>
+              <div class="field-description">How often the right-panel screenshot refreshes when auto-refresh is on. Default 5.</div>
+            </div>
