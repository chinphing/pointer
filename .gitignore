# Ignore common unwanted files globally
**/.DS_Store
**/.env
**/__pycache__/
*.py[cod]
**/.conda/

#Ignore IDE files
.cursor/
.windsurf/

# ignore test files in root dir
/*.test.py
build/
dist/

# Ignore all contents of the virtual environment directory
.venv/

# obsolete folders
memory/
knowledge/custom/
instruments/

# Handle logs directory
logs/**
!logs/**/

# Handle tmp and usr directory
tmp/**
!tmp/**/
usr/**
!usr/**/

# Handle knowledge directory

# Global rule to include .gitkeep files anywhere
!**/.gitkeep

# Optional screen-capture artifact (legacy naming)
agent_history.gif

.agent/**
.claude/**
.skills/**

# ComputerUse (legacy repo paths; data now defaults to usr/workdir/computer/ — see agents/computer/storage_paths.py)
agents/computer/snapshots/
agents/computer/extract_data/
agents/computer/task_done/
data/**
